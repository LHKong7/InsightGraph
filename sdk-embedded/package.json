{
  "name": "@insightgraph/sdk-embedded",
  "version": "0.1.2",
  "description": "Embed the full InsightGraph pipeline (parse -> extract -> resolve -> write -> query) in-process inside your Electron or Node.js app.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@insightgraph/core": "workspace:*",
    "@insightgraph/parser": "workspace:*",
    "@insightgraph/extractor": "workspace:*",
    "@insightgraph/resolver": "workspace:*",
    "@insightgraph/graph": "workspace:*",
    "@insightgraph/retriever": "workspace:*",
    "@insightgraph/agent-runtime": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5",
    "@types/node": "^22.0"
  },
  "keywords": [
    "insightgraph",
    "knowledge-graph",
    "graph-rag",
    "neo4j",
    "electron",
    "sdk"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
