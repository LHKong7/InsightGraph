# InsightGraph environment variables (all prefixed with IG_)
# Copy this file to .env and fill in your values.

# Graph backend: 'neo4j' (default, external server), 'sqlite' (single file,
# translates queries to SQL), or 'falkor' (embedded FalkorDB — Cypher-native,
# auto-starts a managed redis-server child process, zero config).
IG_GRAPH_BACKEND=neo4j

# Neo4j (used when IG_GRAPH_BACKEND=neo4j)
IG_NEO4J_URI=bolt://localhost:7687
IG_NEO4J_USER=neo4j
IG_NEO4J_PASSWORD=insightgraph

# SQLite (used when IG_GRAPH_BACKEND=sqlite)
IG_SQLITE_PATH=./data/insightgraph.sqlite

# FalkorDB (used when IG_GRAPH_BACKEND=falkor). The path is a DIRECTORY that
# persists the embedded redis RDB/AOF files. Leave IG_FALKOR_GRAPH_NAME default
# unless you want to host multiple graphs in the same FalkorDB instance.
IG_FALKOR_PATH=./data/falkor
IG_FALKOR_GRAPH_NAME=insightgraph

# LLM
IG_LLM_MODEL=gpt-4o-mini
IG_LLM_API_KEY=
IG_LLM_BASE_URL=

# Redis
IG_REDIS_URL=redis://localhost:6379

# Storage
IG_UPLOAD_DIR=/tmp/insightgraph/uploads
IG_MAX_FILE_SIZE_MB=100

# Extraction
IG_EXTRACTION_BATCH_SIZE=5
IG_EXTRACTION_MAX_CONCURRENCY=5

# Domain
IG_DOMAIN=default
